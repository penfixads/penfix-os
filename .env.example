# ============================================================
# PENFIX OS — Environment Variables
# Copy to .env.local and fill in real values (never commit .env.local)
# ============================================================

# --- Supabase (client-safe, exposed to browser) ---
# From: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Supabase (SERVER ONLY — never expose, no NEXT_PUBLIC_ prefix) ---
# Used by lib/supabase-admin.ts for privileged operations.
# From: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ------------------------------------------------------------
# In Vercel, set these THREE variables per environment:
#   - Production  -> production Supabase project keys
#   - Preview     -> STAGING Supabase project keys (safe to break)
#   - Development -> staging or a local Supabase (optional)
# See docs/STAGING.md for the full setup.
# ------------------------------------------------------------

# --- Semaphore SMS (SERVER ONLY — never expose) ---
# Used by lib/semaphore.ts to text job-order tracking links to clients.
# From: semaphore.co dashboard > Account > API Key. ~₱0.50/SMS.
SEMAPHORE_API_KEY=your-semaphore-api-key
